# Swiss GovTech Hackathon 2026 — VACD harness backing services.
#
# All backing services run default-on; the harness does not pick a topology.
# Teams build the platform layer themselves (see docs/architecture/patterns.md
# for Pattern A / Pattern B references and
# services/platform-business-logic-example/ for one example implementation).
# The platform layer is NOT included by default — the dev container forwards
# ports 3000/3001/8000/8001/8080/8081 for participants to run their own
# service on. An example platform (Pattern A tracer bullet) is available
# behind the `example` profile: `docker compose --profile example up --wait`.
#
# One CH VACD FHIR server runs by default on 9111. A second identical
# instance for 9112 is defined below but commented out — teams that want
# a producer/consumer split (typically Pattern B) can uncomment it and
# `docker compose up -d fhir-server-2`. The dev container forwards both
# 9111 and 9112 either way.

name: vacd-hackathon

services:
  # CH VACD FHIR API reference server — instance 1.
  # Multi-stage build: Maven runs inside Docker, no local mvn/java prereqs.
  # H2 in-memory, no volume.
  fhir-server-1:
    build:
      context: ./services/ch-vacd-api-reference-server
    image: vacd/ch-vacd-api-reference-server:dev
    container_name: vacd-fhir-server-1
    ports:
      - "9111:9111"
